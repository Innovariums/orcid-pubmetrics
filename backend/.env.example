# OpenAlex: email para el pool gratuito más generoso (polite pool)
OPENALEX_MAILTO=jgasparlopez29@correo.unicordoba.edu.co

# Proveedor de métricas de revista (cuartil)
# Valores válidos: sjr | jcr
JOURNAL_METRICS_PROVIDER=sjr

# Datos SJR (descargados manualmente de scimagojr.com)
SJR_DATA_DIR=../data/sjr

# Clarivate JCR (vacíos hasta que la universidad active suscripción)
JCR_API_KEY=
JCR_API_BASE=https://api.clarivate.com/apis/wos-journal/v1

# Proveedor de comités editoriales
# Valores válidos: open_editors | manual | composite
EDITORIAL_BOARDS_PROVIDER=open_editors
OPEN_EDITORS_DATA_PATH=../data/open_editors/dataset.csv

# Base de datos (SQLite local en Fase 1, Postgres en Fase 3)
DATABASE_URL=sqlite:///./data/app.db

# App
APP_NAME=orcid-pubmetrics
LOG_LEVEL=INFO
